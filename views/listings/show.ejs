<% layout("/layouts/boilerplate") -%>

<div class="show-body">
  <div class="card" style="width: 30rem">

    <h5 class="card-title fs-2"><%= listing.title %></h5>
    <img src="<%= listing.image %>" class="card-img-top show-img" alt="<%= listing.title %>" />

    <div class="card-body">

      <!-- LISTING DETAILS -->
      <div>
        <p class="card-text mb-3">
          <%= listing.description %> <br />
          <b>₹<%= listing.price.toLocaleString("en-IN") %> / night </b> <br />
          <i class="fa-solid fa-location-dot"></i><%= listing.location %> <br />
          <i class="fa-regular fa-map"></i><%= listing.country %>
        </p>
      </div>

      <!-- BUTTONS -->
      <div>
        <form action="/listings/<%= listing._id %>?_method=delete" method="post">
          <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark">Edit</a>
          <button class="btn btn-danger">Delete</button>
        </form>
      </div>



      <!-- create review -->
      <hr class="mt-3 mb-3">
      <div>
        <form action="/listings/<%= listing._id %>/reviews" method="post" class="mt-3 needs-validation">
          <h3>Leave a Review</h3>
          <div class="mb-3">
            <label for="comment" class="form-label">Comment</label>
            <textarea name="review[comment]" class="form-control" id="comment" rows="3" required></textarea>
            <div class="invalid-feedback">Provide a comment.</div>
          </div>
          <div class="rating mt-3">
            <label for="rating" class="form-label">Rating</label>
            <input type="range" class="form-range" name="review[rating]" min="0" max="5" id="rating" />
          </div>
          <div>
            <button type="submit" class="btn offset-3 btn-outline-dark">Submit</button>
          </div>

        </form>
      </div>

      <!-- ALL REVIEWS -->
      <hr class="mt-3 mb-3">
      <h3>All Reviews</h3>
      <div class="row row-cols-1 row-cols-md-2 g-4">
        <% for(review of listing.reviews) { %>
        <div class="col">
          <div class="card review-card ">
            <div class="card-body">
              <p class="card-title fw-light">Username</p>
              <p class="card-text fw-medium"><%= review.comment %></p>
              <p class="card-text fw-light"><%= review.rating %> stars</p>
              <form method="post" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                <button class="btn btn-sm btn-dark">Delete</button>
              </form>
            </div>
          </div>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</div>