<% layout("/layouts/boilerplate") -%>
  <body>
    <h2>Edit Listing</h2>
    <form action="/listings/<%= listing._id %>?_method=put" method="post">
      <input type="text" name="listing[title]" value="<%= listing.title %>" />
      <br /><br />
      <textarea
        name="listing[description]"
        value="<%= listing.description %>"
      ></textarea>
      <br /><br />
      <textarea name="listing[image]" value="<%= listing.image %>"></textarea>
      <br /><br />
      <input type="number" name="listing[price]" value="<%= listing.price.toLocaleString("en-IN") %>" />
      <br /><br />
      <input type="text" name="listing[location]" value="<%= listing.location %>" />
      <br /><br />
      <input type="text" name="listing[country]" value="<%= listing.country %>" />
      <br /><br />
      <button>UPDATE</button>
    </form>
  </body>

